<Window x:Class="Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dragon's Dogma Online"
        Width="1024" Height="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="10" BorderThickness="1" BorderBrush="#55FF8A3A">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="24" ShadowDepth="0" Opacity="0.8" />
        </Border.Effect>
        <Border.Background>
            <ImageBrush ImageSource="Assets/background.png" Stretch="UniformToFill" AlignmentY="Top" />
        </Border.Background>

        <Grid>
            <!-- Scrims for readability: darken top (title) and bottom (controls) -->
            <Border CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#B3000000" Offset="0" />
                        <GradientStop Color="#00000000" Offset="0.22" />
                        <GradientStop Color="#00000000" Offset="0.5" />
                        <GradientStop Color="#CC0A0503" Offset="0.82" />
                        <GradientStop Color="#F2070302" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ===== TOP BAR ===== -->
                <Grid Grid.Row="0" x:Name="TitleBar" Background="#01000000" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <StackPanel Margin="26,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <TextBlock Text="CASUAL DOGMA"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Segoe UI Semibold" FontSize="30" FontWeight="Bold">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFFF6A1E" BlurRadius="20" ShadowDepth="0" Opacity="0.95" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Dragon's Dogma Online Private Server" Margin="2,3,0,0"
                                   Foreground="{StaticResource GoldBrush}"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button x:Name="MinimizeButton" Style="{StaticResource ChromeButton}"
                                Content="&#xE921;" Click="MinimizeButton_Click" ToolTip="Minimize" />
                        <Button x:Name="CloseButton" Style="{StaticResource ChromeButton}"
                                Content="&#xE8BB;" Click="CloseButton_Click" ToolTip="Close" />
                    </StackPanel>
                </Grid>

                <!-- ===== BOTTOM BAR ===== -->
                <Grid Grid.Row="2" Margin="26,0,26,24" VerticalAlignment="Bottom">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Status panel -->
                    <Border Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            CornerRadius="8" Padding="18,14" Background="{StaticResource PanelBrush}"
                            BorderThickness="1" BorderBrush="{StaticResource PanelBorderBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Grid VerticalAlignment="Center" Width="14" Height="14" Margin="0,0,10,0">
                                    <Ellipse x:Name="StatusGlow" Width="14" Height="14" Fill="{StaticResource OfflineRed}" Opacity="0.35" />
                                    <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="{StaticResource OfflineRed}" />
                                </Grid>
                                <TextBlock x:Name="StatusText" Text="CHECKING…"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Segoe UI Semibold" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                                <TextBlock x:Name="ServerNameText" Text="" Margin="12,0,0,0"
                                           Foreground="{StaticResource TextMuted}"
                                           FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           Foreground="{StaticResource GoldBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock x:Name="PlayersText" Text="—"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Segoe UI Semibold" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                <TextBlock Text="players online" Margin="6,0,0,0"
                                           Foreground="{StaticResource TextMuted}"
                                           FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center" />
                                <Border Width="1" Height="14" Background="#33FFFFFF" Margin="14,0" />
                                <TextBlock x:Name="TrafficText" Text=""
                                           Foreground="{StaticResource TextMuted}"
                                           FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Play + utilities -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                        <!-- Account chip -->
                        <StackPanel x:Name="AccountChip" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,7,0" />
                            <TextBlock x:Name="AccountStatusText" Text="Not signed in" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" FontSize="13" />
                            <Button x:Name="SignInLink" Style="{StaticResource LinkButton}" Content="Sign in"
                                    Margin="8,0,0,0" VerticalAlignment="Center" Click="SignInLink_Click" />
                            <Button x:Name="SignOutLink" Style="{StaticResource LinkButton}" Content="Sign out"
                                    Margin="8,0,0,0" VerticalAlignment="Center" Click="SignOutLink_Click" Visibility="Collapsed" />
                        </StackPanel>

                        <!-- Download / update progress (hidden unless patching) -->
                        <StackPanel x:Name="PatchPanel" Width="240" Margin="0,0,0,10" Visibility="Collapsed">
                            <Grid Margin="0,0,0,5">
                                <TextBlock x:Name="PatchStatusText" Text="" HorizontalAlignment="Left"
                                           Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI" FontSize="12" />
                                <TextBlock x:Name="PatchPercentText" Text="" HorizontalAlignment="Right"
                                           Foreground="{StaticResource GoldBrush}" FontFamily="Segoe UI Semibold" FontSize="12" />
                            </Grid>
                            <ProgressBar x:Name="PatchProgressBar" Style="{StaticResource EmberProgress}" />
                            <TextBlock x:Name="PatchDetailText" Text="" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" FontSize="11" />
                        </StackPanel>

                        <Button x:Name="PlayButton" Style="{StaticResource PlayButton}"
                                Width="240" Height="64" Click="PlayButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="PlayButtonIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                <TextBlock x:Name="PlayButtonText" Text="PLAY" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button x:Name="RefreshButton" Style="{StaticResource GhostButton}" Click="RefreshButton_Click" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Refresh" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ServerButton" Style="{StaticResource GhostButton}" Click="ServerButton_Click" Margin="0,0,8,0" ToolTip="Server connection (Lobby / Download)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Server" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="DisplayButton" Style="{StaticResource GhostButton}" Click="DisplayButton_Click" Margin="0,0,8,0" ToolTip="Window size &amp; display options">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Display" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="FolderButton" Style="{StaticResource GhostButton}" Click="FolderButton_Click" ToolTip="Set game client (DDO.exe)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Client" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Toast line for messages -->
                <TextBlock x:Name="ToastText" Grid.Row="2" Margin="26,0,290,2" VerticalAlignment="Bottom"
                           HorizontalAlignment="Left" Foreground="{StaticResource TextMuted}"
                           FontFamily="Segoe UI" FontSize="12" Visibility="Collapsed" />
            </Grid>

            <!-- ===== AUTH OVERLAY ===== -->
            <Border x:Name="AuthOverlay" Background="#CC070302" CornerRadius="10"
                    Visibility="Collapsed">
                <Border Width="380" CornerRadius="10" Padding="28,24" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="#F21B100B" BorderThickness="1" BorderBrush="{StaticResource PanelBorderBrush}">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF000000" BlurRadius="30" ShadowDepth="0" Opacity="0.7" />
                    </Border.Effect>
                    <StackPanel>
                        <Grid>
                            <TextBlock x:Name="AuthTitle" Text="SIGN IN"
                                       Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI Semibold"
                                       FontSize="20" FontWeight="Bold" />
                            <Button Style="{StaticResource ChromeButton}" Content="&#xE8BB;" Width="28" Height="24"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Click="AuthClose_Click" />
                        </Grid>
                        <TextBlock x:Name="AuthSubtitle" Text="Enter your credentials to play Casual Dogma."
                                   Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" FontSize="12"
                                   Margin="0,4,0,18" TextWrapping="Wrap" />

                        <TextBlock Text="ACCOUNT" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,5" />
                        <TextBox x:Name="AccountInput" Style="{StaticResource InputBox}" />

                        <TextBlock Text="PASSWORD" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,12,0,5" />
                        <PasswordBox x:Name="PasswordInput" Style="{StaticResource InputPassword}" />

                        <ToggleButton x:Name="RememberToggle" Style="{StaticResource ToggleChip}" Content="Remember me"
                                      HorizontalAlignment="Left" Margin="0,14,0,0" />

                        <TextBlock x:Name="AuthMessage" Text="" Foreground="{StaticResource OfflineRed}"
                                   FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap" Margin="2,14,0,0"
                                   Visibility="Collapsed" />

                        <Button x:Name="AuthSubmit" Style="{StaticResource AuthButton}" Margin="0,18,0,0"
                                Content="SIGN IN" Click="AuthSubmit_Click" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <TextBlock x:Name="AuthSwitchPrompt" Text="No account yet?" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center" />
                            <Button x:Name="AuthSwitch" Style="{StaticResource LinkButton}" Content="Create one"
                                    Margin="6,0,0,0" VerticalAlignment="Center" Click="AuthSwitch_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ===== DISPLAY OVERLAY ===== -->
            <Border x:Name="DisplayOverlay" Background="#CC070302" CornerRadius="10"
                    Visibility="Collapsed">
                <Border Width="420" CornerRadius="10" Padding="28,24" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="#F21B100B" BorderThickness="1" BorderBrush="{StaticResource PanelBorderBrush}">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF000000" BlurRadius="30" ShadowDepth="0" Opacity="0.7" />
                    </Border.Effect>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="DISPLAY"
                                       Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI Semibold"
                                       FontSize="20" FontWeight="Bold" />
                            <Button Style="{StaticResource ChromeButton}" Content="&#xE8BB;" Width="28" Height="24"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Click="DisplayClose_Click" />
                        </Grid>
                        <TextBlock Text="Choose how the Casual Dogma window opens."
                                   Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" FontSize="12"
                                   Margin="0,4,0,18" TextWrapping="Wrap" />

                        <TextBlock Text="MODE" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,6" />
                        <UniformGrid Columns="2" Height="34">
                            <RadioButton x:Name="WindowedRadio" Style="{StaticResource ToggleChip}" Content="Windowed"
                                         GroupName="DisplayMode" Margin="0,0,4,0" IsChecked="True" />
                            <RadioButton x:Name="FullscreenRadio" Style="{StaticResource ToggleChip}" Content="Fullscreen"
                                         GroupName="DisplayMode" Margin="4,0,0,0" />
                        </UniformGrid>

                        <TextBlock Text="PRESETS" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,16,0,6" />
                        <WrapPanel>
                            <Button Style="{StaticResource PresetChip}" Content="1280 × 720"  Tag="1280x720"  Click="Preset_Click" />
                            <Button Style="{StaticResource PresetChip}" Content="1366 × 768"  Tag="1366x768"  Click="Preset_Click" />
                            <Button Style="{StaticResource PresetChip}" Content="1600 × 900"  Tag="1600x900"  Click="Preset_Click" />
                            <Button Style="{StaticResource PresetChip}" Content="1920 × 1080" Tag="1920x1080" Click="Preset_Click" />
                            <Button Style="{StaticResource PresetChip}" Content="2560 × 1440" Tag="2560x1440" Click="Preset_Click" />
                            <Button Style="{StaticResource PresetChip}" Content="3840 × 2160" Tag="3840x2160" Click="Preset_Click" />
                        </WrapPanel>

                        <TextBlock Text="CUSTOM SIZE" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,8,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="WidthInput" Style="{StaticResource InputBox}" Width="110" />
                            <TextBlock Text="×" Foreground="{StaticResource TextMuted}" FontSize="16" VerticalAlignment="Center" Margin="10,0" />
                            <TextBox x:Name="HeightInput" Style="{StaticResource InputBox}" Width="110" />
                            <ToggleButton x:Name="VSyncToggle" Style="{StaticResource ToggleChip}" Content="VSync"
                                          Margin="16,0,0,0" IsChecked="True" />
                        </StackPanel>

                        <TextBlock x:Name="DisplayMessage" Text="" Foreground="{StaticResource OfflineRed}"
                                   FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap" Margin="2,14,0,0"
                                   Visibility="Collapsed" />

                        <Button x:Name="DisplayApply" Style="{StaticResource AuthButton}" Margin="0,20,0,0"
                                Content="SAVE" Click="DisplayApply_Click" />
                        <TextBlock Text="Applied to the game's config.ini each time you press Play."
                                   Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
            </Border>

            <!-- ===== SERVER OVERLAY ===== -->
            <Border x:Name="ServerOverlay" Background="#CC070302" CornerRadius="10"
                    Visibility="Collapsed">
                <Border Width="420" CornerRadius="10" Padding="28,24" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="#F21B100B" BorderThickness="1" BorderBrush="{StaticResource PanelBorderBrush}">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF000000" BlurRadius="30" ShadowDepth="0" Opacity="0.7" />
                    </Border.Effect>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="SERVER"
                                       Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI Semibold"
                                       FontSize="20" FontWeight="Bold" />
                            <Button Style="{StaticResource ChromeButton}" Content="&#xE8BB;" Width="28" Height="24"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Click="ServerClose_Click" />
                        </Grid>
                        <TextBlock Text="Point the launcher at a different private server."
                                   Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" FontSize="12"
                                   Margin="0,4,0,18" TextWrapping="Wrap" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="LOBBY IP" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,5" />
                                <TextBox x:Name="LobbyIpInput" Style="{StaticResource InputBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="LOBBY PORT" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,5" />
                                <TextBox x:Name="LobbyPortInput" Style="{StaticResource InputBox}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DOWNLOAD IP" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,5" />
                                <TextBox x:Name="DlIpInput" Style="{StaticResource InputBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DOWNLOAD PORT" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,5" />
                                <TextBox x:Name="DlPortInput" Style="{StaticResource InputBox}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Status, account and patch endpoints are derived from the Download host."
                                   Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" FontSize="11"
                                   Margin="2,12,0,0" TextWrapping="Wrap" />

                        <TextBlock x:Name="ServerMessage" Text="" Foreground="{StaticResource OfflineRed}"
                                   FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap" Margin="2,12,0,0"
                                   Visibility="Collapsed" />

                        <Button x:Name="ServerApply" Style="{StaticResource AuthButton}" Margin="0,20,0,0"
                                Content="SAVE &amp; CONNECT" Click="ServerApply_Click" />
                        <Button x:Name="ServerReset" Style="{StaticResource LinkButton}" Content="Reset to Casual Dogma (localhost)"
                                HorizontalAlignment="Center" Margin="0,14,0,0" Click="ServerReset_Click" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
